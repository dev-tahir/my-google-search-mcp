# OpenRouter API key — get one free at https://openrouter.ai
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxx

# Optional: override the default model (default: google/gemini-2.0-flash-001)
OPENROUTER_MODEL=google/gemini-2.0-flash-001

# Shared secret between this MCP server and the Chrome extension.
# Change this from the default and enter the same value in the extension popup.
BRIDGE_TOKEN=mcp-local-dev
